{
  "name": "dibao",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:server": "npm run dev -w @dibao/server",
    "dev:web": "npm run dev -w @dibao/web",
    "e2e": "npm run build && node scripts/e2e/prepare.mjs && playwright test",
    "e2e:install": "playwright install chromium",
    "perf:recommendation": "tsx scripts/perf/recommendation-performance.ts",
    "smoke:docker-recommendation": "node scripts/smoke/docker-recommendation-smoke.mjs",
    "test:ollama:optional": "node scripts/smoke/ollama-probe.mjs",
    "spike:sqlite-vec": "node scripts/spikes/sqlite-vec-node.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
